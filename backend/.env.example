# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional override; defaults to gemini-1.5-flash (free-tier friendly)
GEMINI_MODEL=gemini-1.5-flash

# Port the API listens on
PORT=8787

# Comma-separated list of allowed frontend origins (CORS).
# In dev: http://localhost:3030  ·  In prod: your deployed frontend URL.
FRONTEND_ORIGIN=http://localhost:3030
