# Azure OpenAI (GPT-5.1) configuration
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your_gpt_5_1_deployment_name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional — voice input (mic). Pick ONE of the two providers below.
#
# Option A: Azure OpenAI transcription (e.g. gpt-4o-mini-transcribe, whisper)
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=
#
# Option B: Hugging Face Inference API (free tier — sign in at huggingface.co,
# then create a token at https://huggingface.co/settings/tokens)
HF_API_TOKEN=
HF_TRANSCRIBE_MODEL=openai/whisper-large-v3

# Supabase — chat history persistence (replaces local data/sessions.json).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_xxx_or_anon_key
# Optional — if set, used instead of SUPABASE_KEY (bypasses RLS, server-only).
SUPABASE_SERVICE_ROLE_KEY=

# Port the API listens on
PORT=8787

# Comma-separated list of allowed frontend origins (CORS).
# In dev: http://localhost:3030  ·  In prod: your deployed frontend URL.
FRONTEND_ORIGIN=http://localhost:3030
